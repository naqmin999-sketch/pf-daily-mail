# ════════════════════════════════════════════════════
#  PF Daily Market Intelligence — 환경변수 설정
#  이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요
# ════════════════════════════════════════════════════

# ─── 한국은행 ECOS API ───────────────────────────────
# 발급: https://ecos.bok.or.kr/api/ (무료 회원가입)
ECOS_API_KEY=your_ecos_api_key_here

# ─── 네이버 개발자 API (뉴스 검색) ──────────────────
# 발급: https://developers.naver.com/ (무료)
# 없으면 웹 스크래핑 fallback 사용 (불안정)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ─── 이메일 발송 설정 ────────────────────────────────
# Gmail 사용시: 2단계 인증 후 앱 비밀번호 사용
# 앱 비밀번호 발급: Google계정 → 보안 → 2단계인증 → 앱 비밀번호
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
# 쉼표로 구분, 공백 없이
EMAIL_RECIPIENTS=team@company.com,manager@company.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ─── 리포트 설정 ─────────────────────────────────────
REPORT_TITLE=PF Daily Market Intelligence
TIMEZONE=Asia/Seoul
